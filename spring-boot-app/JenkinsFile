pipeline {

    options {
        skipDefaultCheckout(true)
    }

    agent {
        docker {
            image 'sraav15/jenkins-maven-java21-agent:v1'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/sraav15/terraform-jenkins-argocd-eks.git'
            }
        }

        stage('Git Check') {
            steps {
                sh '''
                    pwd
                    ls -la
                    git status
                '''
            }
        }

        stage('Build and Test') {
            steps {
                sh 'cd spring-boot-app && mvn clean package'
            }
        }

        stage('Static Code Analysis') {
            environment {
                SONAR_URL = "http://98.92.217.27:9000"
            }
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
                    sh '''
                    cd spring-boot-app
                    mvn sonar:sonar \
                    -Dsonar.login=$SONAR_AUTH_TOKEN \
                    -Dsonar.host.url=${SONAR_URL}
                    '''
                }
            }
        }

        stage('Build and Push Docker Image') {

            environment {
                AWS_REGION = "us-east-1"
                ECR_REPO = "884234864409.dkr.ecr.us-east-1.amazonaws.com/ultimate-cicd"
                IMAGE_TAG = "${BUILD_NUMBER}"
            }

            steps {
                sh '''
                    cd spring-boot-app

                    aws ecr get-login-password --region $AWS_REGION | \
                    docker login \
                    --username AWS \
                    --password-stdin 884234864409.dkr.ecr.us-east-1.amazonaws.com

                    docker build -t $ECR_REPO:$IMAGE_TAG .

                    docker push $ECR_REPO:$IMAGE_TAG
                '''
            }
        }

        stage('Update Deployment File') {

            environment {
                GIT_REPO_NAME = "terraform-jenkins-argocd-eks"
                GIT_USER_NAME = "sraav15"
            }

            steps {
                withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {

                    sh '''
                        git config user.email "sravanu09@gmail.com"
                        git config user.name "Sravan Kumar"

                        sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" spring-boot-app-manifests/deployment.yml

                        git add spring-boot-app-manifests/deployment.yml

                        git commit -m "Update deployment image to version ${BUILD_NUMBER}" || echo "No changes to commit"

                        git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
                    '''
                }
            }
        }

    } // close stages

} // close pipeline