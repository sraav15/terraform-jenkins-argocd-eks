pipeline {
  agent {
    docker {
      image 'abhishekf5/maven-abhishek-docker-agent:v1'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock' // mount Docker socket to access the host's Docker daemon
    }
  }
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed'
        //git branch: 'main', url: 'https://github.com/sraav15/terraform-jenkins-argocd-eks.git'
      }
    }
    stage('Build and Test') {
      steps {
        sh 'ls -ltr'
        // build the project and create a JAR file
        sh 'cd terraform-jenkins-argocd-eks/spring-boot-app && mvn clean package'
      }
    }
    stage('Static Code Analysis') {
      environment {
        SONAR_URL = "http://98.92.217.27:9000"
      }
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh 'cd terraform-jenkins-argocd-eks/spring-boot-app && mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
        }
      }
    }
    stage('Build and Push Docker Image') {

  environment {
    AWS_REGION = "us-east-1"
    ECR_REPO = "884234864409.dkr.ecr.us-east-1.amazonaws.com/ultimate-cicd"
    IMAGE_TAG = "${BUILD_NUMBER}"
  }

  steps {

    sh '''
      cd terraform-jenkins-argocd-eks/spring-boot-app

      echo "Login to Amazon ECR"

      aws ecr get-login-password --region $AWS_REGION | \
      docker login \
      --username AWS \
      --password-stdin 884234864409.dkr.ecr.us-east-1.amazonaws.com


      echo "Building Docker image"

      docker build -t $ECR_REPO:$IMAGE_TAG .


      echo "Pushing image to ECR"

      docker push $ECR_REPO:$IMAGE_TAG

    '''
  }
}
    stage('Update Deployment File') {
        environment {
            GIT_REPO_NAME = "terraform-jenkins-argocd-eks"
            GIT_USER_NAME = "sraav15"
        }
        steps {
            withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                sh '''
                    git config user.email "sravanu09@gmail.com"
                    git config user.name "Sravan Kumar"
                    BUILD_NUMBER=${BUILD_NUMBER}
                    sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" terraform-jenkins-argocd-eks/spring-boot-app-manifests/deployment.yml
                    git add terraform-jenkins-argocd-eks/spring-boot-app-manifests/deployment.yml
                    git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                    git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                '''
            }
        }
    }
  }
}
